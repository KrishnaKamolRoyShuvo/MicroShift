@model MicroShift.Models.Review
@{
    ViewData["Title"] = "Leave a Review";
}

<div class="max-w-2xl mx-auto px-4 py-12">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
        
        <div class="bg-brandBlue p-6 text-white text-center">
            <h2 class="text-3xl font-black">Rate Your Experience</h2>
            <p class="mt-2 text-indigo-100 font-medium">For: @ViewBag.JobTitle</p>
            <p class="text-sm text-indigo-200">Reviewing: @ViewBag.RevieweeName</p>
        </div>

        <form asp-action="Create" method="post" class="p-8 space-y-6">
            <input type="hidden" asp-for="JobId" />
            <input type="hidden" asp-for="RevieweeId" />

            <div class="text-center">
                <label class="block text-sm font-bold text-gray-700 mb-4">How was working with them?</label>
                
                <div class="flex justify-center flex-row-reverse gap-2" id="star-rating">
                    <input type="radio" asp-for="Rating" value="5" id="star5" class="peer hidden" required />
                    <label for="star5" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition">
                        <svg class="w-12 h-12 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    </label>

                    <input type="radio" asp-for="Rating" value="4" id="star4" class="peer hidden" />
                    <label for="star4" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition">
                        <svg class="w-12 h-12 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    </label>

                    <input type="radio" asp-for="Rating" value="3" id="star3" class="peer hidden" />
                    <label for="star3" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition">
                        <svg class="w-12 h-12 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    </label>

                    <input type="radio" asp-for="Rating" value="2" id="star2" class="peer hidden" />
                    <label for="star2" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition">
                        <svg class="w-12 h-12 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    </label>

                    <input type="radio" asp-for="Rating" value="1" id="star1" class="peer hidden" />
                    <label for="star1" class="cursor-pointer text-gray-300 peer-hover:text-yellow-400 peer-checked:text-yellow-400 transition">
                        <svg class="w-12 h-12 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    </label>
                </div>
                <span asp-validation-for="Rating" class="text-red-500 text-sm mt-2 block"></span>
            </div>

            <div>
                <label asp-for="Comment" class="block text-sm font-bold text-gray-700 mb-2">Leave a comment (Optional)</label>
                <textarea asp-for="Comment" rows="4" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none transition" placeholder="How was their communication? Quality of work?"></textarea>
            </div>

            <button type="submit" class="w-full bg-gray-900 text-white font-bold text-lg py-4 rounded-xl shadow-lg hover:bg-black transition transform hover:-translate-y-0.5">
                Submit Review
            </button>
        </form>
    </div>
</div>

<style>
    /* This makes clicking a star highlight all the stars to its left */
    #star-rating input:checked ~ label {
        color: #FBBF24; /* yellow-400 */
    }

    #star-rating label:hover,
    #star-rating label:hover ~ label {
        color: #FBBF24;
    }
</style>