@model IEnumerable<MicroShift.Models.Job>
@{
    ViewData["Title"] = "Find Nearby Work";
    
    // Safely parse coordinates from the ViewBag
    string userLat = ViewBag.UserLat != null ? ViewBag.UserLat.ToString() : "null";
    string userLon = ViewBag.UserLon != null ? ViewBag.UserLon.ToString() : "null";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <div class="mb-8">
        <h1 class="text-3xl font-black text-gray-900 tracking-tight">Find Flexible Work</h1>
        <p class="text-gray-500 mt-2 font-medium">Instantly locate jobs happening right around you.</p>
    </div>
    
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200 mb-8 relative z-20">
        <form method="get" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4 items-end">
            
            @if (ViewBag.UserLat != null)
            {
                <input type="hidden" name="userLat" value="@ViewBag.UserLat" />
                <input type="hidden" name="userLon" value="@ViewBag.UserLon" />
            }

            <div class="lg:col-span-2">
                <label class="block text-xs font-bold text-gray-500 mb-1">Category</label>
                <select name="categoryId" class="w-full rounded-xl border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-brandBlue outline-none">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        if (ViewBag.SelectedCategory != null && ViewBag.SelectedCategory == cat.Id)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 mb-1">Max Distance (km)</label>
                <input type="number" name="radius" value="@ViewBag.CurrentRadius" class="w-full rounded-xl border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-brandBlue outline-none" min="1" max="500" />
            </div>

            <div class="flex gap-2 lg:col-span-1">
                <div class="w-1/2">
                    <label class="block text-xs font-bold text-gray-500 mb-1">Min $</label>
                    <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="w-full rounded-xl border border-gray-300 px-2 py-2 focus:ring-2 focus:ring-brandBlue outline-none" placeholder="0" />
                </div>
                <div class="w-1/2">
                    <label class="block text-xs font-bold text-gray-500 mb-1">Max $</label>
                    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="w-full rounded-xl border border-gray-300 px-2 py-2 focus:ring-2 focus:ring-brandBlue outline-none" placeholder="Any" />
                </div>
            </div>

            <div class="flex gap-2 lg:col-span-1">
                <div class="w-1/2">
                    <label class="block text-xs font-bold text-gray-500 mb-1">Type</label>
                    <select name="jobType" class="w-full rounded-xl border border-gray-300 px-2 py-2 focus:ring-2 focus:ring-brandBlue outline-none text-sm">
                        <option value="" selected="@(ViewBag.JobType == null ? "selected" : null)">Any</option>
                        <option value="Offline" selected="@(ViewBag.JobType == "Offline" ? "selected" : null)">Offline</option>
                        <option value="Online" selected="@(ViewBag.JobType == "Online" ? "selected" : null)">Online</option>
                        <option value="Remote" selected="@(ViewBag.JobType == "Remote" ? "selected" : null)">Remote</option>
                    </select>
                </div>
                <div class="w-1/2">
                    <label class="block text-xs font-bold text-gray-500 mb-1">Shift</label>
                    <select name="shift" class="w-full rounded-xl border border-gray-300 px-2 py-2 focus:ring-2 focus:ring-brandBlue outline-none text-sm">
                        <option value="" selected="@(ViewBag.Shift == null ? "selected" : null)">Any</option>
                        <option value="Day" selected="@(ViewBag.Shift == "Day" ? "selected" : null)">Day</option>
                        <option value="Night" selected="@(ViewBag.Shift == "Night" ? "selected" : null)">Night</option>
                        <option value="Flexible" selected="@(ViewBag.Shift == "Flexible" ? "selected" : null)">Flexible</option>
                    </select>
                </div>
            </div>

            <div>
                <button type="submit" class="w-full bg-brandBlue text-white px-4 py-2.5 rounded-xl font-bold hover:bg-blue-700 transition shadow-sm h-[42px]">
                    Search
                </button>
            </div>
        </form>
    </div>

    <div id="map-container" class="w-full h-[400px] bg-gray-100 rounded-3xl overflow-hidden shadow-inner border border-gray-200 mb-10 relative z-10 flex items-center justify-center">
        <div id="gps-loading" class="text-center text-gray-500 flex flex-col items-center">
            <svg class="animate-spin h-8 w-8 text-brandBlue mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <p class="font-bold">Locating nearby jobs...</p>
            <p class="text-xs mt-1">Please allow location access if prompted.</p>
        </div>
        
        <div id="map" class="w-full h-full hidden"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @if (!Model.Any())
        {
            <div class="col-span-full py-12 text-center bg-gray-50 rounded-2xl border border-dashed border-gray-300">
                <p class="text-xl font-bold text-gray-400">No jobs found matching your criteria.</p>
                <p class="text-gray-500 mt-2">Try expanding your search radius or clearing some filters.</p>
            </div>
        }
        
        @foreach (var job in Model)
        {
            <a asp-action="Details" asp-route-id="@job.Id" class="block bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:border-brandBlue/30 transition duration-300 transform hover:-translate-y-1 overflow-hidden flex flex-col h-full relative">
                
                @if (job.IsEmergency)
                {
                    <div class="absolute top-0 right-0 bg-red-500 text-white text-[10px] font-black px-3 py-1 rounded-bl-lg uppercase tracking-wider z-10">
                        Emergency
                    </div>
                }

                <div class="p-6 flex-grow">
                    <div class="flex justify-between items-start mb-4">
                        <span class="inline-block px-3 py-1 bg-indigo-50 text-brandBlue text-xs font-bold rounded-full">
                            @job.Category?.Name
                        </span>
                        <span class="text-lg font-black text-gray-900">$@job.PaymentAmount</span>
                    </div>

                    <h3 class="text-xl font-bold text-gray-900 mb-2 line-clamp-2">@job.Title</h3>
                    <p class="text-sm text-gray-500 mb-6 line-clamp-3">@job.Description</p>
                </div>
                
                <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center mt-auto">
                    <div class="flex items-center gap-2 text-sm font-medium text-gray-600">
                        <svg class="w-4 h-4 text-brandPurple" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        
                        @if (job.JobType == "Online" || job.JobType == "Remote")
                        {
                            <span class="text-brandPurple font-bold">@job.JobType</span>
                        }
                        else if (job.Latitude != 0 && job.Longitude != 0)
                        {
                            <span>@job.DistanceFromUser.ToString("0.0") km away</span>
                        }
                        else
                        {
                            <span>Location unknown</span>
                        }
                    </div>
                    <span class="text-xs text-gray-400 font-bold">@job.CreatedAt.ToString("MMM dd")</span>
                </div>
            </a>
        }
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            
        let userLat = @userLat;
        let userLon = @userLon;

        const mapDiv = document.getElementById('map');
        const loadingDiv = document.getElementById('gps-loading');

        if (userLat === null || userLon === null) {
        if ("geolocation" in navigator) {
        navigator.geolocation.getCurrentPosition(function(position) {
        const currentUrl = new URL(window.location.href);
        currentUrl.searchParams.set('userLat', position.coords.latitude);
        currentUrl.searchParams.set('userLon', position.coords.longitude);
        window.location.href = currentUrl.toString();
        }, function(error) {
        console.error("GPS Error:", error);
        loadingDiv.innerHTML = "<p class='text-red-500 font-bold'>Unable to access GPS.</p><p class='text-xs mt-1 text-gray-500'>Showing default list.</p>";
        });
        } else {
        loadingDiv.innerHTML = "<p class='text-gray-500'>Geolocation not supported.</p>";
        }
        }
        else {
        loadingDiv.classList.add('hidden');
        mapDiv.classList.remove('hidden');

        var map = L.map('map').setView([userLat, userLon], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '© OpenStreetMap'
        }).addTo(map);

        var userIcon = L.divIcon({
        html: '<div class="w-4 h-4 bg-blue-500 rounded-full border-2 border-white shadow-[0_0_10px_rgba(59,130,246,0.8)] animate-pulse"></div>',
        className: '',
        iconSize: [16, 16],
        iconAnchor: [8, 8]
        });

        L.marker([userLat, userLon], { icon: userIcon }).addTo(map)
        .bindPopup("<b class='text-brandBlue'>You are here!</b>").openPopup();

        var jobsData = [
        @foreach (var job in Model)
        {
            if (job.Latitude != 0 && job.Longitude != 0 && job.JobType != "Online" && job.JobType != "Remote")
            {
                <text>
                    {
                    id: @job.Id,
                    title: "@Html.Raw(job.Title.Replace("\"", "\\\"").Replace("\n", " "))",
                    lat: @job.Latitude,
                    lng: @job.Longitude,
                    price: "@job.PaymentAmount",
                    distance: "@job.DistanceFromUser.ToString("0.0")",
                    url: "/Jobs/Details/@job.Id"
                    },
                </text>
            }
        }
        ];

        jobsData.forEach(function(job) {
        var marker = L.marker([job.lat, job.lng]).addTo(map);
        marker.bindPopup(`
        <div class="text-center p-1">
        <p class="font-black text-gray-900 mb-1 leading-tight">${job.title}</p>
        <p class="text-brandBlue font-bold mb-1">$${job.price}</p>
        <p class="text-xs text-gray-500 mb-2">${job.distance} km away</p>
        <a href="${job.url}" class="block w-full bg-gray-900 text-white text-xs font-bold py-1.5 rounded hover:bg-black transition">View Job</a>
        </div>
        `);
        });
        }
        });
    </script>
}