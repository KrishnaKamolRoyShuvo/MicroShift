@model IEnumerable<MicroShift.Models.Job>
@{
    ViewData["Title"] = "Find Work";
}


<div class="max-w-7xl mx-auto px-4 py-8">
    <!-- FILTER BAR -->
    <div class="bg-white p-6 rounded-2xl shadow-md border border-gray-100 mb-8 flex flex-wrap items-center justify-between gap-4">
        <form asp-action="Index" method="get" class="flex items-center gap-4">
            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Search Radius</label>
                <select name="radius" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-brandBlue sm:text-sm rounded-md" onchange="this.form.submit()">
                    <option value="5" selected="@(ViewBag.CurrentRadius == 5)">5 KM</option>
                    <option value="15" selected="@(ViewBag.CurrentRadius == 15)">15 KM</option>
                    <option value="50" selected="@(ViewBag.CurrentRadius == 50)">50 KM</option>
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase">Category</label>
                <select name="categoryId" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-brandBlue sm:text-sm rounded-md" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>
        </form>

        <div class="text-right">
            <span class="text-gray-400 text-sm italic">Showing @Model.Count() jobs near you</span>
        </div>
    </div>

    <!-- JOB GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var job in Model)
        {
            <div class="group relative bg-white rounded-3xl overflow-hidden shadow-lg border @(job.IsEmergency ? "border-red-500 ring-2 ring-red-200 animate-pulse-slow" : "border-gray-100") transition-all hover:shadow-2xl">
                @if (job.IsEmergency)
                {
                    <div class="absolute top-4 right-4 bg-red-600 text-white text-xs font-black px-3 py-1 rounded-full uppercase tracking-widest z-10">
                        Emergency
                    </div>
                }
                
                <!-- Rest of your Job Card design... -->
                <div class="p-6">
                    <h3 class="text-xl font-bold text-gray-900 group-hover:text-brandBlue transition">@job.Title</h3>
                    <p class="text-sm text-gray-500 mt-1">@job.Category?.Name • @job.CreatedAt.ToString("MMM dd, hh:mm tt")</p>
                    
                    <div class="mt-4 flex justify-between items-center">
                        <span class="text-brandBlue font-black text-lg">৳@job.PaymentAmount</span>
                        <a asp-action="Details" asp-route-id="@job.Id" class="px-4 py-2 bg-gray-900 text-white text-sm font-bold rounded-lg hover:bg-brandBlue transition">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row md:justify-between md:items-center mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900">Available Jobs</h1>
            <p class="text-gray-500 mt-2">Find your next micro-shift and start earning.</p>
        </div>
        
        <div class="flex items-center gap-6">
            @if (User.IsInRole("Worker"))
            {
                <form method="get" asp-action="Index" class="flex items-center gap-3 bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-200">
                    <label for="radius" class="text-sm font-bold text-gray-700 whitespace-nowrap">Search Radius:</label>
                    <input type="range" id="radius" name="radius" min="1" max="50" value="@ViewBag.CurrentRadius"
                           class="w-32 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-brandBlue"
                           oninput="document.getElementById('radiusOutput').innerText = this.value + ' km'">
                    <span id="radiusOutput" class="text-sm font-bold text-brandBlue w-12">@ViewBag.CurrentRadius km</span>
                    <button type="submit" class="ml-2 px-3 py-1 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded transition">Apply</button>
                </form>
            }

            @if (User.IsInRole("Employer"))
            {
                <a asp-controller="Jobs" asp-action="Create" class="px-6 py-3 text-white font-medium bg-gradient-to-r from-brandBlue to-brandPurple rounded-lg shadow-md hover:shadow-lg transition">
                    + Post a New Job
                </a>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-20 bg-white rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-xl font-bold text-gray-700">No jobs available right now.</h3>
            <p class="text-gray-500 mt-2">Check back later or post a new job if you are an employer!</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var job in Model)
            {
                <div class="bg-white rounded-2xl shadow-md border border-gray-100 flex flex-col hover:shadow-lg transition overflow-hidden">
                    
                    @if (!string.IsNullOrEmpty(job.JobImageUrl))
                    {
                        <div class="h-48 w-full bg-gray-200">
                            <img src="@job.JobImageUrl" class="w-full h-full object-cover" alt="Job Cover" />
                        </div>
                    }

                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex justify-between items-start mb-4">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium @(job.UrgencyLevel == "Urgent" ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800")">
                                @job.UrgencyLevel
                            </span>
                            <span class="text-lg font-bold text-gray-900">৳@job.PaymentAmount</span>
                        </div>

                        <h3 class="text-xl font-bold text-gray-900 mb-2">@job.Title</h3>

                        @if (job.DistanceFromUser > 0)
                        {
                            <p class="text-sm font-bold text-brandBlue mb-4 flex items-center">
                                📍 @Math.Round(job.DistanceFromUser, 1) km away from you
                            </p>
                        }

                        <p class="text-sm text-gray-500 mb-4 line-clamp-2">@job.Description</p>

                        <div class="mt-auto space-y-2">
                            <div class="flex items-center text-sm text-gray-600">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                @job.Location
                            </div>
                            <div class="flex items-center text-sm text-gray-600">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                Posted by @job.Employer?.FullName
                            </div>
                        </div>

                        <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="block text-center w-full mt-6 py-2 px-4 border border-brandBlue text-brandBlue rounded-lg hover:bg-brandBlue hover:text-white font-bold transition">
                            View Details
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>