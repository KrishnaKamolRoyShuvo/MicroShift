@model MicroShift.Models.Job

@{
    ViewData["Title"] = "Post a New Job";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- CRITICAL UI FIX: Prevent Leaflet from breaking Tailwind Shadows -->
<style>
    #map .leaflet-pane, #map .leaflet-top, #map .leaflet-bottom { z-index: 1 !important; }
    #map .leaflet-control { z-index: 10 !important; }
    #map { z-index: 0 !important; }
    /* Fix for photo inputs not triggering styles */
    .file-selected { border-color: #0F52BA !important; background-color: #EEF2FF !important; }
    .file-selected .file-icon { color: #0F52BA !important; }
    .file-selected .file-label { color: #0F52BA !important; font-weight: 900 !important;}
</style>

<div class="max-w-5xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Create a New Job Post</h1>
    <p class="text-gray-500 mb-8">Fill in the details below to find the best worker in your area.</p>

    <form asp-action="Create" method="post" enctype="multipart/form-data" id="jobForm" class="space-y-8 relative">
        <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-600 p-4 rounded-xl border border-red-200 shadow-sm font-bold"></div>

        <!-- SECTION 1: BASIC DETAILS -->
        <div class="bg-white shadow-xl rounded-2xl p-8 border border-gray-100 relative z-10">
            <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                <span class="bg-brandBlue text-white w-8 h-8 rounded-full flex items-center justify-center mr-3 text-sm font-black">1</span>
                General Information
            </h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
                <div class="space-y-4">
                    <div>
                        <label asp-for="Title" class="block text-sm font-bold text-gray-700 mb-1">What do you need help with?</label>
                        <input asp-for="Title" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandBlue outline-none" placeholder="e.g. Move furniture to 3rd floor" />
                        <span asp-validation-for="Title" class="text-red-500 text-xs font-semibold"></span>
                    </div>

                    <div>
                        <label asp-for="CategoryId" class="block text-sm font-bold text-gray-700 mb-1">Job Category</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandBlue outline-none"></select>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label asp-for="PaymentAmount" class="block text-sm font-bold text-gray-700 mb-1">Budget (৳)</label>
                            <input asp-for="PaymentAmount" type="number" step="0.01" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandBlue" />
                        </div>
                        <div class="flex flex-col justify-end">
                            <div class="flex items-center space-x-2 p-2 bg-red-50 rounded-lg border border-red-100">
                                <input asp-for="IsEmergency" type="checkbox" class="h-4 w-4 text-red-600 rounded cursor-pointer" />
                                <label asp-for="IsEmergency" class="text-xs font-black text-red-700 cursor-pointer">EMERGENCY</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1">Detailed Description</label>
                    <textarea asp-for="Description" rows="8" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandBlue outline-none" placeholder="Explain the job in detail so workers know what to expect..."></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs font-semibold"></span>
                </div>
            </div>
        </div>

        <!-- SECTION 2: PHOTO UPLOAD (RESTORED & INTERACTIVE) -->
        <div class="bg-white shadow-xl rounded-2xl p-8 border border-gray-100 relative z-10">
            <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                <span class="bg-brandBlue text-white w-8 h-8 rounded-full flex items-center justify-center mr-3 text-sm font-black">2</span>
                Job Photos (Optional)
            </h3>
            <p class="text-sm text-gray-500 mb-6">Adding photos helps workers understand the task better.</p>
            
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                @for (int i = 1; i <= 5; i++)
                {
                    <div class="relative group">
                        <!-- Added an ID for JavaScript selection -->
                        <label id="label-photo-@i" class="block w-full h-32 border-2 border-dashed border-gray-300 rounded-xl hover:border-brandBlue hover:bg-blue-50 transition cursor-pointer flex flex-col items-center justify-center text-center p-2">
                            <span class="text-2xl text-gray-400 group-hover:text-brandBlue file-icon">+</span>
                            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-tighter file-label">Photo @i</span>
                            <!-- Added photo-input class for JavaScript event delegation -->
                            <input type="file" name="jobImages" class="hidden photo-input" accept="image/*" data-index="@i" />
                        </label>
                    </div>
                }
            </div>
        </div>

        <!-- SECTION 3: LOCATION PINNING -->
        <div class="bg-white shadow-xl rounded-2xl p-8 border border-gray-100 relative z-10">
            <h3 class="text-xl font-bold text-gray-800 mb-2 flex items-center">
                <span class="bg-brandBlue text-white w-8 h-8 rounded-full flex items-center justify-center mr-3 text-sm font-black">3</span>
                Precise Location
            </h3>
            <p class="text-sm text-gray-500 mb-6">Click on the map to set the exact location where the work will take place.</p>
            
            <!-- Map Container -->
            <div id="map" style="height: 400px;" class="rounded-2xl border-2 border-gray-200 shadow-inner z-0"></div>

            <!-- Coordinate Inputs -->
            <input type="hidden" asp-for="Latitude" id="LatInput" />
            <input type="hidden" asp-for="Longitude" id="LngInput" />
            <span asp-validation-for="Latitude" class="text-red-600 font-extrabold text-sm mt-3 block"></span>

            <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Location" class="block text-sm font-bold text-gray-700 mb-1">General Area Name</label>
                    <input asp-for="Location" class="w-full px-4 py-2 border border-gray-300 rounded-lg" placeholder="e.g. Gulshan-2, Dhaka" />
                    <span asp-validation-for="Location" class="text-red-500 text-xs font-semibold"></span>
                </div>
                <div>
                    <label asp-for="LocationDirections" class="block text-sm font-bold text-gray-700 mb-1">Additional Directions</label>
                    <input asp-for="LocationDirections" class="w-full px-4 py-2 border border-gray-300 rounded-lg" placeholder="Flat No, Road No, or Landmarks..." />
                </div>
            </div>
        </div>

        <button type="submit" class="w-full py-4 bg-brandBlue text-white font-black text-lg rounded-2xl hover:bg-blue-700 transition shadow-xl transform hover:-translate-y-1 relative z-20">
            PUBLISH JOB POST
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // 1. Initialize Map
        var map = L.map('map').setView([23.8103, 90.4125], 13);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var marker;

        map.on('click', function(e) {
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;

            if (marker) {
                marker.setLatLng(e.latlng);
            } else {
                marker = L.marker(e.latlng).addTo(map);
            }

            // Sync hidden inputs for ASP.NET validation
            document.getElementById('LatInput').value = lat;
            document.getElementById('LngInput').value = lng;
        });

        // 2. JavaScript to handle Photo Upload Slots (New Fix)
        const form = document.getElementById('jobForm');
        
        form.addEventListener('change', function(e) {
            // Check if the changed element is one of our photo inputs
            if (e.target.classList.contains('photo-input')) {
                const index = e.target.dataset.index;
                const label = document.getElementById(`label-photo-${index}`);
                const iconSpan = label.querySelector('.file-icon');
                const textSpan = label.querySelector('.file-label');

                if (e.target.files && e.target.files.length > 0) {
                    // SUCESS: File Selected!
                    const filename = e.target.files[0].name;
                    
                    // Update the text to show the filename (truncated if too long)
                    textSpan.textContent = filename.length > 20 ? filename.substring(0, 17) + '...' : filename;
                    
                    // Change the icon to a checkmark
                    iconSpan.textContent = '✓';
                    
                    // Add Tailwind styling classes to show selected state
                    label.classList.add('file-selected');

                } else {
                    // CANCELED: Reset the slot back to default
                    iconSpan.textContent = '+';
                    textSpan.textContent = `Photo ${index}`;
                    label.classList.remove('file-selected');
                }
            }
        });

    </script>
}