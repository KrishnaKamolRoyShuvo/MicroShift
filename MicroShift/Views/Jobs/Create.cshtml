@model MicroShift.Models.Job
@{
    ViewData["Title"] = "Post a New Job";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
        
        <div class="bg-brandBlue p-6 text-white">
            <h1 class="text-3xl font-black">Post a Job</h1>
            <p class="text-indigo-100 mt-2 font-medium">Find the perfect worker in minutes.</p>
        </div>

        <form asp-action="Create" enctype="multipart/form-data" class="p-8 space-y-6">
            
            @if (User.IsInRole("Admin"))
            {
                <div class="bg-indigo-50 border-l-4 border-brandBlue p-4 mb-6 rounded-r-xl shadow-sm">
                    <div class="flex items-start">
                        <div class="flex-shrink-0">
                            <span class="text-brandBlue text-xl animate-pulse">⚡</span>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-black text-brandBlue uppercase tracking-wider">God Mode Active</p>
                            <p class="text-xs text-gray-600 mt-1 font-bold">You are viewing this page as a System Administrator. Form submission is securely disabled to prevent test data from polluting the live marketplace.</p>
                        </div>
                    </div>
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label asp-for="Title" class="block text-sm font-bold text-gray-700 mb-1">Job Title</label>
                    <input asp-for="Title" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" required />
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Description" class="block text-sm font-bold text-gray-700 mb-1">Description</label>
                    <textarea asp-for="Description" rows="4" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" required></textarea>
                </div>
            </div>

            <div class="border-t border-gray-100 pt-6">
                <label class="block text-sm font-bold text-gray-700 mb-1">Upload Task Photos (Max 5)</label>
                <p class="text-xs text-gray-500 mb-3">Upload clear photos to help workers understand the task. (Metadata is preserved for security & dispute resolution).</p>
                <input type="file" name="images" id="imageUpload" multiple accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-bold file:bg-indigo-50 file:text-brandBlue hover:file:bg-indigo-100 transition" />
                <p id="fileLimitWarning" class="text-red-500 text-xs mt-2 hidden font-bold">You can only upload a maximum of 5 images.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 border-t border-gray-100 pt-6">
                <div>
                    <label asp-for="CategoryId" class="block text-sm font-bold text-gray-700 mb-1">Category</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" required>
                        <option value="">Select Category...</option>
                    </select>
                </div>
                <div>
                    <label asp-for="JobType" class="block text-sm font-bold text-gray-700 mb-1">Job Type</label>
                    <select asp-for="JobType" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none">
                        <option value="Offline">Offline / In-Person</option>
                        <option value="Online">Online / Remote</option>
                        <option value="Remote">Remote</option>
                    </select>
                </div>
                <div>
                    <label asp-for="Shift" class="block text-sm font-bold text-gray-700 mb-1">Shift</label>
                    <select asp-for="Shift" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none">
                        <option value="Flexible">Flexible / Anytime</option>
                        <option value="Day">Day Shift</option>
                        <option value="Night">Night Shift</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-gray-100 pt-6">
                <div>
                    <label asp-for="PaymentAmount" class="block text-sm font-bold text-gray-700 mb-1">Total Payment Amount (৳)</label>
                    <input asp-for="PaymentAmount" type="number" step="0.01" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" required />
                </div>
                <div>
                    <label asp-for="RequiredSkills" class="block text-sm font-bold text-gray-700 mb-1">Required Skills</label>
                    <input asp-for="RequiredSkills" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" placeholder="e.g. English, Driving" />
                </div>
            </div>

            <div class="border-t border-gray-100 pt-6">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Location Details</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
                    <div>
                        <label asp-for="Location" class="block text-sm font-bold text-gray-700 mb-1">General Area</label>
                        <input asp-for="Location" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" required />
                    </div>
                    <div>
                        <label asp-for="LocationDirections" class="block text-sm font-bold text-gray-700 mb-1">Exact Directions</label>
                        <input asp-for="LocationDirections" class="w-full rounded-xl border border-gray-300 px-4 py-3 focus:ring-2 focus:ring-brandBlue outline-none" />
                    </div>
                </div>

                <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 gap-4">
                        <div>
                            <p class="font-bold text-gray-900 text-sm">Pinpoint the Job Location</p>
                            <p class="text-xs text-gray-500 mt-1" id="gps-status">Click the map to place a pin manually, or click Auto-Detect.</p>
                        </div>
                        <button type="button" id="get-location-btn" class="px-4 py-2 bg-brandBlue text-white text-xs font-bold rounded-lg shadow hover:bg-blue-700 transition flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            Auto-Detect Current Location
                        </button>
                    </div>
                    
                    <div id="picker-map" class="w-full h-[300px] rounded-xl border border-gray-300 z-10 cursor-crosshair"></div>
                </div>
                
                <input type="hidden" asp-for="Latitude" id="Latitude" required />
                <input type="hidden" asp-for="Longitude" id="Longitude" required />
                <span asp-validation-for="Latitude" class="text-red-500 text-xs mt-2 block">Please click the map to set a pin.</span>
            </div>

            <div class="border-t border-gray-100 pt-6 flex items-center gap-3">
                <input asp-for="IsEmergency" type="checkbox" class="w-5 h-5 text-red-600 rounded focus:ring-red-500" />
                <label asp-for="IsEmergency" class="text-sm font-bold text-gray-900">Mark as Emergency</label>
            </div>

            <div class="border-t border-gray-100 pt-6 flex justify-end items-center gap-4">
                <a asp-action="Index" class="px-6 py-3 text-gray-600 font-bold hover:text-brandBlue transition">Cancel</a>
                
                @if (User.IsInRole("Admin"))
                {
                    <div class="flex items-center gap-3 bg-slate-900 border border-brandBlue rounded-xl px-6 py-3 shadow-sm cursor-not-allowed">
                        <span class="text-brandBlue text-sm font-black uppercase tracking-widest">⚡ System Admin</span>
                        <span class="text-xs text-gray-400 font-bold border-l border-gray-600 pl-3">Disabled</span>
                    </div>
                    <button type="submit" id="submitBtn" class="hidden" disabled></button>
                }
                else
                {
                    <button type="submit" id="submitBtn" class="bg-gray-900 text-white px-8 py-3 rounded-xl font-bold text-lg shadow-lg hover:bg-black transition">
                        Post Job Live
                    </button>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        // --- 1. Image Limit Enforcer ---
        const fileInput = document.getElementById('imageUpload');
        const submitBtn = document.getElementById('submitBtn');
        const warning = document.getElementById('fileLimitWarning');

        fileInput.addEventListener('change', function() {
        if (this.files.length > 5) {
        warning.classList.remove('hidden');
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
        warning.classList.add('hidden');
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
        });

        // --- 2. Interactive Map Logic ---
        const latInput = document.getElementById('Latitude');
        const lngInput = document.getElementById('Longitude');
        const statusText = document.getElementById('gps-status');

        // Default to Dhaka coordinates
        var map = L.map('picker-map').setView([23.8103, 90.4125], 11);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

        var marker = null;

        function setMarker(lat, lng, source) {
        if (marker !== null) {
        map.removeLayer(marker);
        }
        marker = L.marker([lat, lng]).addTo(map);
        latInput.value = lat;
        lngInput.value = lng;
        statusText.innerText = `Location set via ${source}: ${lat.toFixed(4)}, ${lng.toFixed(4)} ✅`;
        statusText.className = "text-xs mt-1 font-bold text-green-600";
        }

        // A. Manual Click Setting
        map.on('click', function(e) {
        setMarker(e.latlng.lat, e.latlng.lng, "Manual Map Click");
        });

        // B. Auto-Detect Setting
        document.getElementById('get-location-btn').addEventListener('click', function() {
        statusText.innerText = "Searching for GPS satellite...";
        statusText.className = "text-xs mt-1 font-bold text-brandBlue";
                
        if ("geolocation" in navigator) {
        navigator.geolocation.getCurrentPosition(function(position) {
        const lat = position.coords.latitude;
        const lng = position.coords.longitude;
        map.setView([lat, lng], 15);
        setMarker(lat, lng, "Auto-Detect");
        }, function(error) {
        statusText.innerText = "GPS Error. Please click manually on the map.";
        statusText.className = "text-xs mt-1 font-bold text-red-600";
        });
        } else {
        statusText.innerText = "Geolocation not supported. Click the map.";
        }
        });

        // Auto-trigger GPS on load if requested
        document.getElementById('get-location-btn').click();
        });
    </script>
}