@model MicroShift.Models.Job
@using Microsoft.AspNetCore.Identity
@inject UserManager<MicroShift.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.Title;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

@if (Model.Status == "Cancelled")
{
    <div class="max-w-3xl mx-auto px-4 py-20 text-center font-sans">
        <div class="bg-red-50 border-2 border-red-200 rounded-3xl p-12 shadow-sm">
            <svg class="w-20 h-20 text-red-500 mx-auto mb-6 opacity-75" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            <h1 class="text-4xl font-black text-red-900 mb-4 tracking-tight">Job Taken Down</h1>
            <p class="text-lg text-red-700 font-medium mb-8">This content has been removed by MicroShift administration for violating platform policies or community guidelines.</p>
            <a href="/Jobs" class="inline-block bg-red-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-red-700 transition shadow-lg">
                Return to Job Feed
            </a>
        </div>
    </div>
}
else
{
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
            
            <div class="p-8 border-b border-gray-100 bg-gray-50">
                <div class="flex flex-col md:flex-row justify-between items-start gap-4">
                    <div>
                        @if (Model.IsEmergency || Model.UrgencyLevel == "Urgent")
                        {
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-red-100 text-red-800 mb-4 shadow-sm animate-pulse">
                                Emergency Priority
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-green-100 text-green-800 mb-4 shadow-sm">
                                Normal Priority
                            </span>
                        }
                        
                        <h1 class="text-3xl font-extrabold text-gray-900">@Model.Title</h1>
                        <p class="text-gray-500 mt-2 flex items-center font-medium">
                            <svg class="w-5 h-5 mr-2 text-brandBlue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            Posted by @(Model.Employer?.FullName ?? Model.Employer?.Email ?? "Employer")
                        </p>
                        
                        <div class="flex gap-2 mt-4">
                            <span class="px-3 py-1 bg-white border border-gray-200 text-gray-600 text-xs font-bold rounded-lg shadow-sm">
                                @(string.IsNullOrEmpty(Model.JobType) ? "Offline" : Model.JobType)
                            </span>
                            <span class="px-3 py-1 bg-white border border-gray-200 text-gray-600 text-xs font-bold rounded-lg shadow-sm">
                                @(string.IsNullOrEmpty(Model.Shift) ? "Flexible Shift" : Model.Shift)
                            </span>
                        </div>
                    </div>
                    
                    <div class="text-left md:text-right">
                        <p class="text-4xl font-black text-brandBlue">৳@Model.PaymentAmount</p>
                        <p class="text-sm text-gray-500 mt-1 font-medium">Total Payment</p>
                    </div>
                </div>
            </div>

            <div class="p-8 grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <div class="md:col-span-2 space-y-8">
                    
                    @{
                        var photos = new[] { Model.JobImageUrl, Model.JobImageUrl2, Model.JobImageUrl3, Model.JobImageUrl4, Model.JobImageUrl5 }
                            .Where(url => !string.IsNullOrEmpty(url)).ToList();
                    }
                    
                    @if (photos.Any())
                    {
                        <div class="space-y-4">
                            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wider">Task Evidence / Photos</h3>
                            <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm">
                                <img src="@photos.First()" alt="Job Cover" class="w-full h-80 object-cover cursor-pointer hover:opacity-90 transition" onclick="window.open(this.src)" />
                            </div>
                            
                            @if (photos.Count > 1)
                            {
                                <div class="grid grid-cols-4 gap-4">
                                    @foreach (var photo in photos.Skip(1))
                                    {
                                        <img src="@photo" class="h-24 w-full rounded-lg object-cover cursor-pointer hover:scale-105 transition shadow-sm border border-gray-200" onclick="window.open(this.src)" />
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div>
                        <h3 class="text-xl font-bold text-gray-900 mb-3 border-b pb-2">Job Description</h3>
                        <p class="text-gray-600 whitespace-pre-wrap leading-relaxed">@Model.Description</p>
                    </div>
                    
                    <div>
                        <h3 class="text-xl font-bold text-gray-900 mb-3 border-b pb-2">Required Skills</h3>
                        <div class="flex flex-wrap gap-2">
                            @if (!string.IsNullOrEmpty(Model.RequiredSkills))
                            {
                                foreach (var skill in Model.RequiredSkills.Split(','))
                                {
                                    <span class="bg-indigo-50 text-brandBlue px-4 py-2 rounded-lg text-sm font-bold shadow-sm">@skill.Trim()</span>
                                }
                            }
                            else
                            {
                                <span class="text-gray-500 italic">No specific skills listed.</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    
                    <div class="bg-gray-50 p-6 rounded-xl border border-gray-200 text-center shadow-sm">
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <p class="text-sm text-gray-500 font-medium mb-3">You must be logged in to apply or chat.</p>
                            <a asp-area="Identity" asp-page="/Account/Login" class="w-full inline-block py-3 px-4 bg-gray-900 text-white rounded-xl font-bold shadow hover:bg-black transition">Log In</a>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <div class="bg-indigo-50 border border-brandBlue rounded-xl p-4 text-center mb-4 shadow-inner">
                                <p class="text-sm text-brandBlue font-black uppercase tracking-widest mb-1">⚡ System Admin</p>
                                <p class="text-[10px] text-gray-600 font-bold">Applications disabled in God Mode.</p>
                            </div>
            
                            <a asp-controller="Chat" asp-action="Index" asp-route-jobId="@Model.Id" asp-route-receiverId="@Model.EmployerId" class="w-full flex items-center justify-center gap-2 py-3 px-4 bg-gray-900 text-white rounded-xl font-bold shadow-lg hover:bg-black transition">
                                <svg class="w-4 h-4 text-brandBlue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                                Message as Admin
                            </a>
                        }
                        else if (User.IsInRole("Employer"))
                        {
                            <p class="text-sm text-red-600 font-bold">Employers cannot apply for jobs.</p>
                        }
                        else if (ViewBag.HasApplied != null && ViewBag.HasApplied)
                        {
                            <div class="bg-green-100 text-green-800 p-4 rounded-xl font-bold border border-green-200 shadow-inner mb-4">
                                ✓ Application Sent!
                            </div>
            
                            <a asp-controller="Chat" asp-action="Index" asp-route-jobId="@Model.Id" asp-route-receiverId="@Model.EmployerId" class="w-full inline-block py-3 px-4 bg-gray-900 text-white rounded-xl font-bold shadow-lg hover:bg-black transition">
                                💬 Message Employer
                            </a>
                        }
                        else
                        {
                            <form asp-controller="Jobs" asp-action="Apply" asp-route-id="@Model.Id" method="post" class="mb-4">
                                <button type="submit" class="w-full py-4 px-4 bg-brandBlue text-white rounded-xl shadow-lg font-black text-lg hover:bg-blue-700 transition transform hover:-translate-y-0.5">
                                    Apply Now
                                </button>
                            </form>
            
                            <a asp-controller="Chat" asp-action="Index" asp-route-jobId="@Model.Id" asp-route-receiverId="@Model.EmployerId" class="w-full inline-block py-3 px-4 bg-white text-gray-900 border border-gray-300 rounded-xl font-bold shadow-sm hover:bg-gray-50 transition">
                                💬 Ask a Question
                            </a>
                        }
                    </div>

                    <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm relative z-0">
                        <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
                            <h3 class="text-sm font-bold text-gray-900">📍 @Model.Location</h3>
                            @if (!string.IsNullOrEmpty(Model.LocationDirections))
                            {
                                <p class="text-xs text-gray-500 mt-1 italic">@Model.LocationDirections</p>
                            }
                        </div>
                        
                        @if (Model.JobType == "Online" || Model.JobType == "Remote")
                        {
                            <div class="h-56 w-full bg-indigo-50 flex items-center justify-center p-6 text-center">
                                <div>
                                    <svg class="w-12 h-12 text-brandBlue mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                                    <p class="text-sm font-bold text-brandBlue">Remote / Online Job</p>
                                    <p class="text-xs text-gray-500 mt-1">Can be completed from anywhere.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div id="jobMap" class="h-56 w-full z-0"></div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (Model.Status != "Cancelled")
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            // Only load the map script if it's an offline job
            if ('@Model.JobType' !== 'Online' && '@Model.JobType' !== 'Remote') {
            var lat = @(Model.Latitude != 0 ? Model.Latitude : 23.8103);
            var lng = @(Model.Longitude != 0 ? Model.Longitude : 90.4125);
                
            var map = L.map('jobMap').setView([lat, lng], 15);
                
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
            }).addTo(map);

            L.marker([lat, lng]).addTo(map)
            .bindPopup('<b>@Html.Raw(Model.Title.Replace("'", "\\'"))</b><br>@Html.Raw(Model.Location.Replace("'", "\\'"))')
            .openPopup();
                    
            setTimeout(function() { map.invalidateSize(); }, 200);
            }
        </script>
    }
}