@model MicroShift.Models.ApplicationUser
@{
    ViewData["Title"] = Model.FullName + " - Profile";
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 font-sans">

    <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">

        <div class="h-48 bg-gradient-to-r from-slate-900 to-[#0A192F] relative">
            <div class="absolute inset-0 opacity-20 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNmZmZmZmYiLz48L3N2Zz4=')]"></div>
            <div class="absolute bottom-0 w-full h-1.5 bg-[#D4AF37]"></div>
        </div>

        <div class="px-8 pb-8 relative">

            <div class="flex flex-col md:flex-row justify-between items-start md:items-end -mt-16 mb-6 gap-4">

                <div class="relative">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img src="@Model.ProfilePictureUrl" alt="@Model.FullName" class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover bg-white relative z-10" />
                    }
                    else
                    {
                        <div class="w-32 h-32 rounded-full border-4 border-white shadow-lg bg-gray-100 flex items-center justify-center text-5xl font-black text-gray-400 relative z-10">
                            @(string.IsNullOrEmpty(Model.FullName) ? "?" : Model.FullName.Substring(0, 1).ToUpper())
                        </div>
                    }

                    <div class="absolute -bottom-2 -right-4 z-20">
                        @if (ViewBag.UserTier == "Top Rated")
                        {
                            <span class="bg-slate-900 text-[#D4AF37] border-2 border-[#D4AF37] font-black text-xs px-4 py-1.5 rounded-full shadow-lg flex items-center gap-1 tracking-widest uppercase">
                                ⭐ Top Rated
                            </span>
                        }
                        else if (ViewBag.UserTier == "Professional")
                        {
                            <span class="bg-brandBlue text-white border-2 border-white font-bold text-xs px-4 py-1.5 rounded-full shadow-md tracking-wider uppercase">
                                ✓ Professional
                            </span>
                        }
                        else
                        {
                            <span class="bg-gray-200 text-gray-700 border-2 border-white font-bold text-xs px-4 py-1.5 rounded-full shadow-md tracking-wider uppercase">
                                🌱 New
                            </span>
                        }
                    </div>
                </div>

                <div class="flex gap-3 w-full md:w-auto">
                    @if (User.Identity.Name != Model.UserName)
                    {
                        <a href="/Chat/Index?receiverId=@Model.Id" class="flex-1 md:flex-none px-6 py-3 bg-gray-100 text-gray-800 font-bold rounded-xl hover:bg-gray-200 transition shadow-sm text-center border border-gray-200">
                            Message
                        </a>
                        @if (ViewBag.PrimaryRole == "Worker")
                        {
                            <a href="/Jobs" class="flex-1 md:flex-none px-6 py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-black transition shadow-lg text-center border border-[#D4AF37]">
                                Hire Worker
                            </a>
                        }
                    }
                    else
                    {
                        <a href="/Identity/Account/Manage" class="px-6 py-3 bg-brandBlue text-white font-bold rounded-xl hover:bg-blue-700 transition shadow-sm border border-blue-800">
                            Edit My Profile
                        </a>
                    }
                </div>
            </div>

            <div>
                <h1 class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight">@Model.FullName</h1>
                <p class="text-lg text-gray-500 font-medium mt-1 flex items-center gap-2">
                    <span class="bg-gray-100 text-gray-700 px-2 py-0.5 rounded text-sm font-bold border border-gray-200">@ViewBag.PrimaryRole</span>
                    • 📍 @(string.IsNullOrEmpty(Model.Location) ? "Location Unknown" : Model.Location)
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">

        <div class="md:col-span-1 space-y-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-xs font-black text-gray-400 uppercase tracking-widest mb-6 border-b pb-2">Platform Statistics</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-sm text-gray-500 font-bold mb-1">Jobs Completed</p>
                        <p class="text-3xl font-black text-gray-900">@ViewBag.JobsCompleted</p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-bold mb-1">Lifetime Volume</p>
                        <p class="text-3xl font-black text-green-600">৳@ViewBag.LifetimeVolume.ToString("N0")</p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-bold mb-1">Overall Rating</p>
                        <div class="flex items-center gap-2">
                            <p class="text-3xl font-black text-gray-900">@Model.AverageRating.ToString("0.0")</p>
                            <div class="flex text-yellow-400 text-xl">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(Model.AverageRating))
                                    {
                                        <span>★</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-200">★</span>
                                    }
                                }
                            </div>
                        </div>
                        <p class="text-xs text-gray-400 mt-1 font-bold">Based on @Model.TotalReviews reviews</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="md:col-span-2 space-y-6">

            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-xl font-black text-gray-900 mb-4 flex items-center gap-2">
                    <span class="text-brandBlue">📋</span> About
                </h3>
                @if (string.IsNullOrEmpty(Model.Interests))
                {
                    <p class="text-gray-500 italic">This user hasn't written a bio yet.</p>
                }
                else
                {
                    <p class="text-gray-700 leading-relaxed text-lg">@Model.Interests</p>
                }
            </div>

            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-xl font-black text-gray-900 mb-4 flex items-center gap-2">
                    <span class="text-brandBlue">🎯</span> Skills & Expertise
                </h3>
                @if (string.IsNullOrEmpty(Model.Skills))
                {
                    <p class="text-gray-500 italic">No specific skills listed.</p>
                }
                else
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var skill in Model.Skills.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="bg-indigo-50 border border-indigo-100 text-brandBlue px-4 py-2 rounded-xl text-sm font-bold hover:bg-brandBlue hover:text-white transition cursor-default">
                                @skill.Trim()
                            </span>
                        }
                    </div>
                }
            </div>
            <!-- PRIVATE DETAILS (ONLY VISIBLE TO OWNER) -->
            @if (ViewBag.IsOwnProfile)
            {
                <div class="bg-indigo-50 p-8 rounded-2xl shadow-sm border border-indigo-100">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-xl font-black text-gray-900 flex items-center gap-2">
                            <span class="text-brandBlue">🔒</span> Private Account Details
                        </h3>
                        <span class="text-xs font-bold bg-white text-indigo-400 px-2 py-1 rounded border border-indigo-100 uppercase tracking-widest">Only visible to you</span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm text-gray-800">
                        <div class="bg-white p-3 rounded-lg border border-indigo-50">
                            <p class="text-xs text-gray-400 font-bold uppercase mb-1">Email Address</p>
                            <p class="font-bold">@Model.Email</p>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-indigo-50">
                            <p class="text-xs text-gray-400 font-bold uppercase mb-1">Phone Number</p>
                            <p class="font-bold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not Provided" : Model.PhoneNumber)</p>
                        </div>
                        <div class="bg-white p-3 rounded-lg border border-indigo-50 sm:col-span-2">
                            <p class="text-xs text-gray-400 font-bold uppercase mb-1">Exact Mailing Address</p>
                            <p class="font-bold">@(string.IsNullOrEmpty(Model.Address) ? "Not Provided" : Model.Address)</p>
                        </div>
                    </div>
                </div>
            }

            <!-- REVIEWS SECTION -->
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-xl font-black text-gray-900 mb-6 flex items-center gap-2 border-b pb-4">
                    <span class="text-[#D4AF37]">💬</span> Written Reviews (@Model.TotalReviews)
                </h3>

                @if (ViewBag.Reviews == null /* Replace with: !ViewBag.Reviews.Any() once db is connected */)
                {
                    <p class="text-gray-500 italic">No written reviews yet.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var review in ViewBag.Reviews)
                        {
                            <div class="bg-blue-700 p-5 rounded-xl border border-gray-500 relative ">
                                <div class="flex justify-between items-start mb-2">
                                    <div>
                                        <p class="text-white font-bold text-sm">@review.Reviewer?.FullName</p>
                                        <p class="text-gray-100 text-xs">@review.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    <div class="flex text-[#e0b93a] text-lg">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {

                                                <span class="text-gray-100">★</span>
                                            }
                                        }
                                    </div>
                                </div>
                                <p class="text-gray-100 text-sm leading-relaxed">"@review.Comment"</p>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
</div>