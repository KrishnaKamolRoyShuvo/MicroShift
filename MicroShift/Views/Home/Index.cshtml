@{
    ViewData["Title"] = "Home Page";
}

<div class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNlNWU3ZWIiLz48L3N2Zz4=')] opacity-50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-32 text-center">
        <span class="inline-block py-1 px-3 rounded-full bg-indigo-50 text-brandBlue text-sm font-semibold mb-6 border border-indigo-100">
            🚀 The Real-Time Job Marketplace
        </span>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-gray-900 mb-6">
            Find Flexible Work <br />
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-brandBlue to-brandPurple">Instantly Near You.</span>
        </h1>
        <p class="mt-4 max-w-2xl text-lg md:text-xl text-gray-500 mx-auto mb-10">
            Whether you need urgent help or want to earn extra cash today, MicroShift connects workers and employers in minutes.
        </p>
        <div class="flex justify-center gap-4">
            <a asp-controller="Jobs" asp-action="Index" class="px-8 py-4 text-base font-medium rounded-full text-white bg-gradient-to-r from-brandBlue to-brandPurple shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition">
                Find Nearby Jobs
            </a>
            <a asp-controller="Jobs" asp-action="Create" class="px-8 py-4 text-base font-medium rounded-full text-brandBlue bg-white border-2 border-indigo-100 hover:bg-indigo-50 shadow-sm transition">
                Post a Job for Free
            </a>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex justify-between items-center mb-8">
        <h2 class="text-2xl font-bold text-gray-900">🔥 Happening Right Now</h2>
        <a href="#" class="text-brandBlue font-medium hover:underline">View all jobs &rarr;</a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
            <div class="flex justify-between items-start mb-4">
                <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded-md">Urgent</span>
                <span class="text-gray-400 text-sm">2 mins ago</span>
            </div>
            <h3 class="font-bold text-lg text-gray-900">Furniture Delivery Assistant</h3>
            <p class="text-sm text-gray-500 mb-4">sh enterprise</p>
            <div class="flex items-center text-sm text-gray-600 mb-4">
                <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                1.2 km away
            </div>
            <div class="flex justify-between items-center">
                <span class="font-bold text-xl text-brandBlue">৳500<span class="text-sm text-gray-400 font-normal">/job</span></span>
                <button class="px-4 py-2 bg-gray-900 text-white text-sm rounded-lg hover:bg-gray-800 transition">Apply Now</button>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
            <div class="flex justify-between items-start mb-4">
                <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded-md">Event</span>
                <span class="text-gray-400 text-sm">15 mins ago</span>
            </div>
            <h3 class="font-bold text-lg text-gray-900">Photography Assistant</h3>
            <p class="text-sm text-gray-500 mb-4">Sh Compute</p>
            <div class="flex items-center text-sm text-gray-600 mb-4">
                <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                3.5 km away
            </div>
            <div class="flex justify-between items-center">
                <span class="font-bold text-xl text-brandBlue">৳1200<span class="text-sm text-gray-400 font-normal">/day</span></span>
                <button class="px-4 py-2 bg-gray-900 text-white text-sm rounded-lg hover:bg-gray-800 transition">Apply Now</button>
            </div>
        </div>

        <div class="bg-gradient-to-br from-brandBlue to-brandPurple p-6 rounded-2xl shadow-md text-white">
            <h3 class="font-bold text-lg mb-2">Top Earner This Week</h3>
            <div class="flex items-center gap-4 mt-4">
                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-brandBlue font-bold text-xl">RA</div>
                <div>
                    <p class="font-bold">Rafin Ali</p>
                    <p class="text-sm text-indigo-200">Completed 12 jobs</p>
                </div>
            </div>
            <p class="mt-6 text-sm text-indigo-100 italic">"MicroShift helped me find local gigs whenever I have free time!"</p>
        </div>
    </div>
</div>