@model IEnumerable<MicroShift.Models.Transaction>
@{
    ViewData["Title"] = "My Wallet";
}

<div class="max-w-4xl mx-auto px-4 py-8 font-sans">
    <div class="bg-gradient-to-r from-brandBlue to-purple-600 rounded-2xl shadow-lg p-8 text-white mb-8 flex justify-between items-center">
        <div>
            <p class="text-sm font-medium opacity-80 uppercase tracking-wider mb-1">Available Balance</p>
            <h1 class="text-5xl font-black tracking-tight">৳@ViewBag.CurrentBalance.ToString("0.00")</h1>
        </div>
        <button class="bg-white text-brandBlue font-bold py-3 px-6 rounded-xl hover:bg-gray-50 transition shadow-sm" onclick="alert('Withdrawal system coming soon!')">
            Request Payout
        </button>
    </div>

    <h3 class="text-lg font-bold text-gray-900 mb-4">Transaction History</h3>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        @if (!Model.Any())
        {
            <div class="p-8 text-center text-gray-500">No transactions yet. Complete jobs to earn money!</div>
        }
        else
        {
            <ul class="divide-y divide-gray-100">
                @foreach (var t in Model)
                {
                    <li class="p-4 flex justify-between items-center hover:bg-gray-50 transition">
                        <div>
                            <p class="font-bold text-gray-900 text-sm">@t.Description</p>
                            <p class="text-xs text-gray-400">@t.CreatedAt.ToString("MMM dd, yyyy - h:mm tt")</p>
                        </div>
                        <div class="text-right">
                            <span class="font-bold @(t.Type == "Credit" ? "text-green-600" : "text-gray-900")">
                                @(t.Type == "Credit" ? "+" : "-")৳@t.Amount.ToString("0.00")
                            </span>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>