@model MicroShift.Models.Job
@{
    ViewData["Title"] = "Forensic Dispute Courtroom";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    // Find the specific application involved in the dispute
    var disputedApp = Model.JobApplications.FirstOrDefault(a => a.Status == "Disputed" || !string.IsNullOrEmpty(a.DisputeInitiator));
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">

    <div class="mb-4">
        <a href="/Admin/Disputes" class="text-sm font-bold text-brandBlue hover:underline flex items-center mb-2">
            ← Back to Queue
        </a>
    </div>

    <div class="bg-gray-900 rounded-2xl p-6 mb-6 text-white shadow-xl flex flex-col md:flex-row justify-between items-start md:items-center">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <span class="px-3 py-1 bg-red-600 text-white text-xs font-black uppercase tracking-widest rounded">Active Dispute</span>
                <span class="text-gray-400 font-bold">Case #@Model.Id</span>
            </div>
            <h1 class="text-3xl font-black mb-1">@Model.Title</h1>
            <p class="text-gray-400">Total Escrow Value: <span class="text-green-400 font-bold">৳@Model.PaymentAmount</span></p>
        </div>
        <div class="mt-4 md:mt-0 bg-gray-800 p-4 rounded-xl border border-gray-700 w-full md:w-auto">
            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider mb-2">The Absolute Baseline (Job Posted)</p>
            <div class="flex items-center gap-4">
                @if (!string.IsNullOrEmpty(Model.JobImageUrl))
                {
                    <a href="@Model.JobImageUrl" target="_blank">
                        <img src="@Model.JobImageUrl" class="w-16 h-16 rounded border border-gray-600 object-cover hover:opacity-80" />
                    </a>
                }
                <div>
                    <p class="text-sm font-bold text-blue-400">Server Time: @Model.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")</p>
                    @if (Model.ExifCaptureTime.HasValue)
                    {
                        <p class="text-sm font-bold text-purple-400">EXIF Capture: @Model.ExifCaptureTime.Value.ToString("MMM dd, yyyy - hh:mm tt")</p>
                    }
                    else
                    {
                        <p class="text-sm font-bold text-red-500">EXIF Capture: MISSING / STRIPPED</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (disputedApp == null)
    {
        <div class="bg-white p-8 rounded-2xl text-center text-gray-500 font-bold border border-gray-200">
            No disputed application found for this job.
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">

            <div class="bg-white rounded-2xl border-2 @(disputedApp.DisputeInitiator == "Employer" ? "border-red-400" : "border-gray-200") shadow-lg overflow-hidden">
                <div class="bg-gray-50 p-4 border-b border-gray-200 flex justify-between items-center">
                    <h2 class="text-xl font-black text-gray-900">Employer: @(Model.Employer?.FullName ?? "Unknown")</h2>
                    @if (disputedApp.DisputeInitiator == "Employer")
                    {
                        <span class="px-3 py-1 bg-red-100 text-red-800 text-xs font-bold rounded-full">Initiated Dispute</span>
                    }
                </div>

                <div class="p-6">
                    @if (string.IsNullOrEmpty(disputedApp.EmployerDisputeText))
                    {
                        <div class="text-center p-8 bg-gray-50 rounded-xl border border-gray-200">
                            <p class="text-gray-500 font-bold mb-2">Waiting for Employer Defense...</p>
                            <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded">GHOSTING TIMER ACTIVE</span>
                        </div>
                    }
                    else
                    {
                        <div class="mb-6">
                            <p class="text-xs text-gray-500 font-bold uppercase mb-1">Official Statement</p>
                            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 text-sm text-gray-800 italic">
                                "@disputedApp.EmployerDisputeText"
                            </div>
                        </div>

                        <div>
                            <p class="text-xs text-gray-500 font-bold uppercase mb-2">Photographic Evidence</p>
                            @if (!string.IsNullOrEmpty(disputedApp.EmployerDisputeImageUrl))
                            {
                                <a href="@disputedApp.EmployerDisputeImageUrl" target="_blank">
                                    <img src="@disputedApp.EmployerDisputeImageUrl" class="w-full h-48 object-cover rounded-xl border border-gray-200 shadow-sm mb-3 hover:opacity-90" />
                                </a>
                            }

                            <div class="bg-slate-900 p-4 rounded-xl text-white space-y-2">
                                @if (disputedApp.EmployerDisputeExifTime.HasValue)
                                {
                                    <p class="text-sm font-bold"><span class="text-gray-400">EXIF Capture:</span> <span class="text-purple-400">@disputedApp.EmployerDisputeExifTime.Value.ToString("MMM dd, hh:mm tt")</span></p>

                                    // FRAUD CHECK: Did they take the dispute photo BEFORE the job was even posted?
                                    if (Model.ExifCaptureTime.HasValue && disputedApp.EmployerDisputeExifTime.Value < Model.ExifCaptureTime.Value)
                                    {
                                        <div class="mt-3 p-2 bg-red-600 rounded text-white text-xs font-black uppercase text-center animate-pulse">
                                            ⚠️ FRAUD FLAG: Image taken before job was posted!
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-sm font-bold"><span class="text-gray-400">EXIF Capture:</span> <span class="text-red-500">METADATA STRIPPED</span></p>
                                    <div class="mt-3 p-2 bg-orange-600 rounded text-white text-xs font-bold uppercase text-center">
                                        Warning: Possible Screenshot / Web Download
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="bg-white rounded-2xl border-2 @(disputedApp.DisputeInitiator == "Worker" ? "border-red-400" : "border-gray-200") shadow-lg overflow-hidden">
                <div class="bg-gray-50 p-4 border-b border-gray-200 flex justify-between items-center">
                    <h2 class="text-xl font-black text-gray-900">Worker: @(disputedApp.Worker?.FullName ?? "Unknown")</h2>
                    @if (disputedApp.DisputeInitiator == "Worker")
                    {
                        <span class="px-3 py-1 bg-red-100 text-red-800 text-xs font-bold rounded-full">Initiated Dispute</span>
                    }
                </div>

                <div class="p-6">
                    @if (string.IsNullOrEmpty(disputedApp.WorkerDisputeText))
                    {
                        <div class="text-center p-8 bg-gray-50 rounded-xl border border-gray-200">
                            <p class="text-gray-500 font-bold mb-2">Waiting for Worker Defense...</p>
                            <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded">GHOSTING TIMER ACTIVE</span>
                        </div>
                    }
                    else
                    {
                        <div class="mb-6">
                            <p class="text-xs text-gray-500 font-bold uppercase mb-1">Official Statement</p>
                            <div class="bg-gray-50 p-4 rounded-xl border border-gray-200 text-sm text-gray-800 italic">
                                "@disputedApp.WorkerDisputeText"
                            </div>
                        </div>

                        <div>
                            <p class="text-xs text-gray-500 font-bold uppercase mb-2">Photographic Evidence</p>
                            @if (!string.IsNullOrEmpty(disputedApp.WorkerDisputeImageUrl))
                            {
                                <a href="@disputedApp.WorkerDisputeImageUrl" target="_blank">
                                    <img src="@disputedApp.WorkerDisputeImageUrl" class="w-full h-48 object-cover rounded-xl border border-gray-200 shadow-sm mb-3 hover:opacity-90" />
                                </a>
                            }

                            <div class="bg-slate-900 p-4 rounded-xl text-white space-y-2">
                                <p class="text-sm"><span class="text-gray-400">Server Upload:</span> @(disputedApp.WorkerEvidenceDate?.ToString("MMM dd, hh:mm tt") ?? "Unknown")</p>

                                @if (disputedApp.WorkerDisputeExifTime.HasValue)
                                {
                                    <p class="text-sm font-bold"><span class="text-gray-400">EXIF Capture:</span> <span class="text-purple-400">@disputedApp.WorkerDisputeExifTime.Value.ToString("MMM dd, hh:mm tt")</span></p>

                                    // FRAUD CHECK: Did they take the dispute photo BEFORE the job was even posted?
                                    if (Model.ExifCaptureTime.HasValue && disputedApp.WorkerDisputeExifTime.Value < Model.ExifCaptureTime.Value)
                                    {
                                        <div class="mt-3 p-2 bg-red-600 rounded text-white text-xs font-black uppercase text-center animate-pulse">
                                            ⚠️ FRAUD FLAG: Image taken before job was posted!
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-sm font-bold"><span class="text-gray-400">EXIF Capture:</span> <span class="text-red-500">METADATA STRIPPED</span></p>
                                    <div class="mt-3 p-2 bg-orange-600 rounded text-white text-xs font-bold uppercase text-center">
                                        Warning: Possible Screenshot / Web Download
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>

        <div class="bg-white border-t-4 border-adminHighlight shadow-xl rounded-2xl p-8 sticky top-6">
            <h2 class="text-2xl font-black text-gray-900 mb-2">Issue Final Ruling</h2>
            <p class="text-sm text-gray-500 mb-6 font-medium">This action is irreversible. Funds will be routed immediately based on your decision.</p>

            <form asp-controller="Admin" asp-action="ResolveDispute" method="post" id="rulingForm" class="space-y-6">
                <input type="hidden" name="jobId" value="@Model.Id" />

                <div>
                    <label class="block text-sm font-bold text-gray-900 mb-2">Assign Fault (For user trust metrics):</label>
                    <div class="grid grid-cols-3 gap-2">
                        <label class="cursor-pointer">
                            <input type="radio" name="faultAssignedTo" value="Employer" class="peer sr-only" required />
                            <div class="text-center px-2 py-3 border border-gray-200 rounded-xl peer-checked:bg-red-50 peer-checked:border-red-500 peer-checked:text-red-700 font-bold text-sm transition hover:bg-gray-50">Employer Fault</div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="faultAssignedTo" value="Worker" class="peer sr-only" required />
                            <div class="text-center px-2 py-3 border border-gray-200 rounded-xl peer-checked:bg-red-50 peer-checked:border-red-500 peer-checked:text-red-700 font-bold text-sm transition hover:bg-gray-50">Worker Fault</div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="faultAssignedTo" value="Mutual" class="peer sr-only" required />
                            <div class="text-center px-2 py-3 border border-gray-200 rounded-xl peer-checked:bg-indigo-50 peer-checked:border-brandBlue peer-checked:text-brandBlue font-bold text-sm transition hover:bg-gray-50">Mutual / No Fault</div>
                        </label>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-900 mb-2">Official Investigation Note (Private):</label>
                    <textarea name="adminNote" rows="3" class="w-full border border-gray-300 rounded-xl p-3 text-sm focus:ring-2 focus:ring-brandBlue outline-none" placeholder="Detail exactly why you made this ruling for future audits..." required></textarea>
                </div>

                <div class="space-y-4 pt-4 border-t border-gray-100">
                    <label class="block cursor-pointer relative">
                        <input type="radio" name="resolutionType" value="ForceComplete" class="peer sr-only" required />
                        <div class="p-4 border-2 border-gray-200 rounded-xl peer-checked:border-green-500 peer-checked:bg-green-50 transition hover:border-gray-300">
                            <div class="flex justify-between items-center mb-1">
                                <span class="font-black text-gray-900">Force Complete (Pay Worker)</span>
                                <span class="text-green-600 font-bold">৳@Model.PaymentAmount</span>
                            </div>
                            <p class="text-xs text-gray-500">Worker successfully completed the job. Escrow will be released to them minus commission.</p>
                        </div>
                    </label>

                    <label class="block cursor-pointer relative">
                        <input type="radio" name="resolutionType" value="CancelRefund" class="peer sr-only" required />
                        <div class="p-4 border-2 border-gray-200 rounded-xl peer-checked:border-red-500 peer-checked:bg-red-50 transition hover:border-gray-300">
                            <div class="flex justify-between items-center mb-1">
                                <span class="font-black text-gray-900">Cancel Job (Refund Employer)</span>
                                <span class="text-red-600 font-bold">৳@Model.PaymentAmount</span>
                            </div>
                            <p class="text-xs text-gray-500">Task was not completed to standard. Full escrow will be returned to the Employer.</p>
                        </div>
                    </label>

                    <label class="block cursor-pointer relative">
                        <input type="radio" name="resolutionType" value="PartialSettlement" class="peer sr-only" id="partialRadio" required />
                        <div class="p-4 border-2 border-gray-200 rounded-xl peer-checked:border-brandBlue peer-checked:bg-indigo-50 transition hover:border-gray-300">
                            <div class="flex justify-between items-center mb-2">
                                <span class="font-black text-gray-900">Partial Settlement</span>
                                <span class="text-brandBlue font-bold">Split Funds</span>
                            </div>
                            <p class="text-xs text-gray-500 mb-3">Adjust the final payout. The remaining balance will be refunded to the employer.</p>

                            <div id="partialInputDiv" class="hidden flex items-center gap-2">
                                <span class="text-sm font-bold text-gray-700">Pay Worker: ৳</span>
                                <input type="number" name="newPaymentAmount" id="partialAmount" max="@Model.PaymentAmount" step="0.01" class="border border-gray-300 rounded-lg px-2 py-1 w-24 text-sm font-bold" placeholder="0.00" disabled />
                                <span class="text-xs text-red-500 hidden font-bold" id="partialWarning">Cannot exceed original escrow!</span>
                            </div>
                        </div>
                    </label>
                </div>

                <button type="submit" class="w-full mt-4 bg-adminDark text-white py-4 rounded-xl font-black tracking-wider hover:bg-black transition shadow-lg flex justify-center items-center gap-2">
                    <svg class="w-5 h-5 text-adminHighlight" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
                    EXECUTE RULING
                </button>
            </form>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Logic to show/hide the Partial Settlement input box
        const radios = document.querySelectorAll('input[name="resolutionType"]');
        const partialDiv = document.getElementById('partialInputDiv');
        const partialInput = document.getElementById('partialAmount');
        const maxAmount = @Model.PaymentAmount;
        const warning = document.getElementById('partialWarning');
        const form = document.getElementById('rulingForm');

        radios.forEach(radio => {
            radio.addEventListener('change', function() {
                if (document.getElementById('partialRadio').checked) {
                    partialDiv.classList.remove('hidden');
                    partialInput.disabled = false;
                    partialInput.required = true;
                } else {
                    partialDiv.classList.add('hidden');
                    partialInput.disabled = true;
                    partialInput.required = false;
                    warning.classList.add('hidden');
                }
            });
        });

        // Prevent admin from paying out more money than what is in escrow
        form.addEventListener('submit', function(e) {
            if (document.getElementById('partialRadio').checked) {
                if (parseFloat(partialInput.value) > maxAmount) {
                    e.preventDefault();
                    warning.classList.remove('hidden');
                    partialInput.focus();
                }
            }
        });
    </script>
}