@model IEnumerable<MicroShift.Models.Category>
@{
    ViewData["Title"] = "Platform Settings";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans">
    
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h1 class="text-3xl font-black text-gray-900 tracking-tight">Platform Economics</h1>
        <p class="text-gray-500 mt-1 font-medium">Manage job categories and adjust platform commission rates.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="bg-gray-50 px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                    <h3 class="font-bold text-gray-900">Active Job Categories</h3>
                    <span class="text-xs text-gray-500">Changes apply to future posts only.</span>
                </div>
                
                <ul class="divide-y divide-gray-100">
                    @foreach (var cat in Model)
                    {
                        <li class="p-6 hover:bg-gray-50 transition flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                            <div>
                                <p class="font-black text-lg text-gray-900">@cat.Name</p>
                                <p class="text-xs text-gray-500 mt-1">ID: #@cat.Id</p>
                            </div>
                            
                            <form asp-action="UpdateCategory" method="post" class="flex items-center gap-3 bg-white p-2 rounded-xl border border-gray-200 shadow-sm">
                                <input type="hidden" name="id" value="@cat.Id" />
                                <div class="flex items-center">
                                    <span class="text-sm font-bold text-gray-500 pl-3">Cut:</span>
                                    <input type="number" name="commissionPercentage" value="@cat.CategoryCommissionPercentage" step="0.1" min="0" max="100" class="w-16 text-right font-black text-brandBlue outline-none bg-transparent px-2" />
                                    <span class="text-sm font-bold text-gray-500 pr-3">%</span>
                                </div>
                                <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-xs font-bold hover:bg-black transition">
                                    Save
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 sticky top-6">
                <h3 class="font-black text-gray-900 mb-4 border-b pb-2">Add New Category</h3>
                
                <form asp-action="AddCategory" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-700 mb-1">Category Name</label>
                        <input type="text" name="name" placeholder="e.g. Graphic Design" required class="w-full rounded-xl border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-brandBlue outline-none text-sm" />
                    </div>
                    
                    <div>
                        <label class="block text-xs font-bold text-gray-700 mb-1">Default Commission (%)</label>
                        <input type="number" name="commissionPercentage" value="10.0" step="0.1" min="0" max="100" required class="w-full rounded-xl border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-brandBlue outline-none text-sm font-bold text-brandBlue" />
                        <p class="text-[10px] text-gray-500 mt-1">How much of the total payment MicroShift keeps.</p>
                    </div>

                    <button type="submit" class="w-full mt-4 bg-brandBlue text-white py-3 rounded-xl font-bold tracking-wide hover:bg-blue-700 transition shadow-md">
                        + Create Category
                    </button>
                </form>
            </div>
        </div>
        
    </div>
</div>