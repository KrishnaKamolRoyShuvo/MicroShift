@using Microsoft.AspNetCore.Identity
@using MicroShift.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);

        <li class="nav-item">
            <!-- Links to the new Profile Controller, passing the User's ID -->
            <a class="nav-link text-dark font-bold hover:text-brandBlue transition" href="/Profile/User/@currentUser?.Id" title="Manage Profile">
                <span class="text-brandBlue">@(currentUser?.FullName ?? "User")</span>
            </a>
        
            <form class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="text-sm font-medium text-red-500 hover:text-red-700 transition bg-transparent border-0 cursor-pointer">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a class="text-sm font-medium text-gray-600 hover:text-brandBlue transition" style="padding: 10px;" asp-area="Identity" asp-page="/Account/Login">Log in</a>
        
            <a class="text-sm font-medium text-white bg-gradient-to-r from-brandBlue to-brandPurple px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition" asp-area="Identity" asp-page="/Account/Register">
                Join MicroShift
            </a>
        </li>
    }
</ul>