@using Microsoft.AspNetCore.Identity
@using MicroShift.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="flex items-center space-x-4 m-0 p-0 list-none">
    @if (SignInManager.IsSignedIn(User))
    {
        <li>
            <a class="text-sm font-medium text-gray-700 hover:text-brandBlue" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Hello, @UserManager.GetUserName(User)!
            </a>
        </li>
        <li>
            <form class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="text-sm font-medium text-red-500 hover:text-red-700 transition bg-transparent border-0 cursor-pointer">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a class="text-sm font-medium text-gray-600 hover:text-brandBlue transition" asp-area="Identity" asp-page="/Account/Login">Log in</a>
        </li>
        <li>
            <a class="text-sm font-medium text-white bg-gradient-to-r from-brandBlue to-brandPurple px-5 py-2.5 rounded-full shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition" asp-area="Identity" asp-page="/Account/Register">
                Join MicroShift
            </a>
        </li>
    }
</ul>
