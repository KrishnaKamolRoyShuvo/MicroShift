<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MicroShift Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brandBlue: '#4F46E5', // Matches your main site
                        adminDark: '#0F172A', // Deep slate for sidebar
                        adminHighlight: '#F59E0B' // Gold accent
                    }
                }
            }
        }
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50 text-gray-900 flex h-screen overflow-hidden font-sans">

    <aside id="adminSidebar" class="bg-adminDark text-gray-300 w-64 flex-shrink-0 transition-all duration-300 flex flex-col relative z-20 shadow-2xl overflow-y-auto">
        
        <div class="h-16 flex items-center px-6 border-b border-gray-800 bg-gray-900">
            <span id="sidebarLogo" class="text-white font-black text-xl tracking-wider uppercase flex items-center gap-2">
                <span class="text-adminHighlight">⚡</span> MicroShift
            </span>
        </div>

        <nav class="flex-1 py-6 px-3 space-y-1">
            <p class="px-3 text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 sidebar-text">Command Center</p>
            
            <a href="/Admin/Dashboard" class="flex items-center px-3 py-2.5 rounded-lg hover:bg-gray-800 hover:text-white group transition @(Context.Request.Path.StartsWithSegments("/Admin/Dashboard") ? "bg-gray-800 text-adminHighlight" : "")">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                <span class="sidebar-text font-medium">Global Analytics</span>
            </a>

            <a href="/Admin/Disputes" class="flex items-center px-3 py-2.5 rounded-lg hover:bg-gray-800 hover:text-white group transition @(Context.Request.Path.StartsWithSegments("/Admin/Disputes") || Context.Request.Path.StartsWithSegments("/Admin/DisputeDetails") ? "bg-gray-800 text-adminHighlight" : "")">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
                <span class="sidebar-text font-medium @(Context.Request.Path.StartsWithSegments("/Admin/Disputes") ? "" : "text-red-400 group-hover:text-red-300")">Disputes (Courtroom)</span>
            </a>

            <a href="#" class="flex items-center px-3 py-2.5 rounded-lg hover:bg-gray-800 hover:text-white group transition opacity-50 cursor-not-allowed" title="Coming Soon">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <span class="sidebar-text font-medium">Transaction Ledger</span>
            </a>

            <p class="px-3 text-xs font-bold text-gray-500 uppercase tracking-wider mt-6 mb-2 sidebar-text">Moderation & Setup</p>

            <a href="/Admin/Users" class="flex items-center px-3 py-2.5 rounded-lg hover:bg-gray-800 hover:text-white group transition @(Context.Request.Path.StartsWithSegments("/Admin/Users") ? "bg-gray-800 text-adminHighlight" : "")">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <span class="sidebar-text font-medium">User Moderation</span>
            </a>

            <a href="/Admin/Jobs" class="flex items-center px-3 py-2.5 rounded-lg hover:bg-gray-800 hover:text-white group transition @(Context.Request.Path.StartsWithSegments("/Admin/Jobs") ? "bg-gray-800 text-adminHighlight" : "")">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                <span class="sidebar-text font-medium">Job Moderation</span>
            </a>

            <a href="/Admin/Settings" class="flex items-center px-3 py-2.5 rounded-lg hover:bg-gray-800 hover:text-white group transition @(Context.Request.Path.StartsWithSegments("/Admin/Settings") ? "bg-gray-800 text-adminHighlight" : "")">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="sidebar-text font-medium">Platform Settings</span>
            </a>
        </nav>

        <div class="p-4 border-t border-gray-800 bg-gray-900 flex items-center">
            <div class="w-8 h-8 rounded-full bg-adminHighlight flex items-center justify-center text-gray-900 font-bold flex-shrink-0">
                A
            </div>
            <div class="ml-3 sidebar-text overflow-hidden">
                <p class="text-sm font-bold text-white truncate">Administrator</p>
                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="~/">
                    <button type="submit" class="text-xs text-gray-400 hover:text-white transition">Sign Out</button>
                </form>
            </div>
        </div>
    </aside>

    <div class="flex-1 flex flex-col overflow-hidden h-screen">
        
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 z-10 flex-shrink-0">
            <div class="flex items-center">
                <button id="toggleSidebar" class="text-gray-500 hover:text-brandBlue focus:outline-none p-2 rounded-lg hover:bg-gray-100 transition mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
                
                <div class="hidden md:flex bg-gray-100 rounded-lg p-1 border border-gray-200">
                    <button class="px-3 py-1 text-xs font-bold rounded-md bg-white text-brandBlue shadow-sm">Admin View</button>
                    <button class="px-3 py-1 text-xs font-bold rounded-md text-gray-500 hover:text-gray-900">Worker View</button>
                    <button class="px-3 py-1 text-xs font-bold rounded-md text-gray-500 hover:text-gray-900">Employer View</button>
                </div>
            </div>
            
            <div class="flex items-center gap-4">
                <a href="/" target="_blank" class="text-sm font-bold text-gray-600 hover:text-brandBlue flex items-center gap-1 transition">
                    Open Live Site
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
            </div>
        </header>

        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 relative">
            @RenderBody()
        </main>
    </div>

    <script>
        const sidebar = document.getElementById('adminSidebar');
        const toggleBtn = document.getElementById('toggleSidebar');
        const sidebarTexts = document.querySelectorAll('.sidebar-text');
        const sidebarLogo = document.getElementById('sidebarLogo');
        let isCollapsed = false;

        toggleBtn.addEventListener('click', () => {
            isCollapsed = !isCollapsed;
            if (isCollapsed) {
                sidebar.classList.remove('w-64');
                sidebar.classList.add('w-16');
                sidebarTexts.forEach(el => el.classList.add('hidden'));
                sidebarLogo.innerHTML = '<span class="text-adminHighlight">⚡</span>';
            } else {
                sidebar.classList.remove('w-16');
                sidebar.classList.add('w-64');
                sidebarTexts.forEach(el => el.classList.remove('hidden'));
                sidebarLogo.innerHTML = '<span class="text-adminHighlight">⚡</span> MicroShift';
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>