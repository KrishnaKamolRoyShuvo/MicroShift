@{
    ViewData["Title"] = "Account Recovery - Step 2";
}
<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
        <div class="text-center mb-6">
            <h2 class="text-2xl font-extrabold text-gray-900">Phone Verification</h2>
            <p class="mt-2 text-sm text-gray-600">
                Registered phone ending in <strong class="text-brandBlue text-base">**@ViewBag.PhoneHint</strong>.
            </p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 text-red-600 p-4 rounded-lg text-sm mb-6 border border-red-200 font-bold shadow-sm">
                <div asp-validation-summary="All"></div>
            </div>
        }

        @if (ViewBag.IsLockedOut == true)
        {
            <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-6 text-center shadow-inner">
                <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-yellow-100 mb-4 text-yellow-600 text-2xl">⏳</div>
                <h3 class="text-lg font-bold text-yellow-800 mb-2">Verification Locked</h3>
                <div class="mt-4 py-2 px-4 bg-white rounded-lg border border-yellow-300 inline-block shadow-sm">
                    <span class="text-yellow-800 font-bold">Cooldown: @ViewBag.LockoutMinutes minute(s)</span>
                </div>
                <div class="mt-6">
                    <button onclick="window.location.reload();" class="text-sm font-bold text-brandBlue hover:text-blue-700 underline transition">Refresh Status</button>
                </div>
            </div>
        }
        else
        {
            <form asp-controller="Password" asp-action="VerifyPhone" method="post" class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Registered Phone Number</label>
                    <input name="phoneNumber" type="tel" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-brandBlue focus:border-brandBlue" placeholder="e.g., 018XX-XXXXXX">
                </div>
                <button type="submit" class="w-full py-3 bg-brandBlue text-white font-bold rounded-lg hover:bg-blue-700 transition shadow-md">Verify & Proceed</button>
            </form>
        }
    </div>
</div>