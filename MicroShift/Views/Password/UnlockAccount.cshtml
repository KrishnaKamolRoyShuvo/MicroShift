@{
    ViewData["Title"] = "Account Frozen";
}
<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl border border-red-200 p-8">
        <div class="text-center mb-6">
            <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-red-100 mb-4 text-red-600 text-3xl">
                🔒
            </div>
            <h2 class="text-2xl font-extrabold text-red-700">Account Frozen</h2>
            <p class="mt-2 text-sm text-gray-600">
                Due to multiple failed attempts, your account has been locked for your protection. You must verify your National Identity Document (NID) to regain access.
            </p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-4 border border-red-200">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form asp-controller="Password" asp-action="UnlockAccount" method="post" class="space-y-6">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">National ID (NID) Number</label>
                <input name="nationalId" type="text" required class="w-full px-4 py-3 border border-red-300 rounded-lg focus:ring-red-500 focus:border-red-500" placeholder="Enter your NID number...">
            </div>
            
            <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-lg text-white bg-red-600 hover:bg-red-700 transition shadow-md">
                Verify Identity & Unlock Account
            </button>
        </form>
    </div>
</div>