@{
    ViewData["Title"] = "Create New Password";
}
<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
        <h2 class="text-center text-2xl font-extrabold text-gray-900 mb-6">Create New Password</h2>
        
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-4 border border-red-200">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form asp-controller="Password" asp-action="Reset" method="post" class="space-y-4">
            <input type="hidden" name="token" value="@ViewBag.Token" />
            <input type="hidden" name="email" value="@ViewBag.Email" />
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
                <input name="newPassword" type="password" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brandBlue focus:border-brandBlue" placeholder="••••••••">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
                <input name="confirmPassword" type="password" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-brandBlue focus:border-brandBlue" placeholder="••••••••">
            </div>
            <button type="submit" class="w-full py-3 bg-brandBlue text-white font-bold rounded-lg hover:bg-blue-700 transition shadow-md mt-4">
                Update Password
            </button>
        </form>
    </div>
</div>