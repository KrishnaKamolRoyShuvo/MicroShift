@{
    ViewData["Title"] = "Account Recovery - Step 1";
}
<div class="min-h-[70vh] flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
        <div class="text-center mb-6">
            <h2 class="text-2xl font-extrabold text-gray-900">Account Recovery</h2>
            <p class="mt-2 text-sm text-gray-600">To protect your account, please verify your identity.</p>
        </div>
        
        <form asp-controller="Password" asp-action="VerifyLastPassword" method="post" class="space-y-6">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">Enter the last password you remember</label>
                <input name="lastPassword" type="password" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-brandBlue focus:border-brandBlue" placeholder="••••••••">
                <p class="text-xs text-gray-500 mt-2">If you don't remember any past passwords, just click Next.</p>
            </div>
            
            <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-lg text-white bg-brandBlue hover:bg-blue-700 transition shadow-md">
                Next Step
            </button>
        </form>
    </div>
</div>