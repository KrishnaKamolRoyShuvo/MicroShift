@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div>
            <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
                Welcome back
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Log in to your MicroShift account
            </p>
        </div>
        <form id="account" method="post" class="mt-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4" role="alert"></div>
            
            <div class="space-y-4">
                <div>
                    <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700">Email address</label>
                    <input asp-for="Input.Email" autocomplete="username" aria-required="true" class="appearance-none relative block w-full px-3 py-3 mt-1 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-lg focus:outline-none focus:ring-brandBlue focus:border-brandBlue focus:z-10 sm:text-sm" placeholder="Email address" />
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700">Password</label>
                    <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" class="appearance-none relative block w-full px-3 py-3 mt-1 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-lg focus:outline-none focus:ring-brandBlue focus:border-brandBlue focus:z-10 sm:text-sm" placeholder="Password" />
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input asp-for="Input.RememberMe" class="h-4 w-4 text-brandBlue focus:ring-brandBlue border-gray-300 rounded" />
                    <label asp-for="Input.RememberMe" class="ml-2 block text-sm text-gray-900">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <div class="text-sm">
                    <a id="forgot-password" href="/Password/Forgot" class="text-sm font-medium text-brandBlue hover:text-blue-500">Forgot your password?</a>
                </div>
            </div>

            <div>
                <button id="login-submit" type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-gradient-to-r from-brandBlue to-brandPurple hover:shadow-lg transform hover:-translate-y-0.5 transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brandBlue">
                    Sign in
                </button>
            </div>
        </form>

        <div class="mt-6 text-center text-sm">
            <p class="text-gray-600">
                Don't have an account?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="font-medium text-brandBlue hover:text-brandPurple">
                    Register as a new user
                </a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}